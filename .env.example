# Copia este archivo como .env.local y completa con los valores de tu
# proyecto Supabase (Project Settings → API). La anon key es pública.
# Si dejas estas variables vacías, la app funciona en modo demo (localStorage).
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-public-key
